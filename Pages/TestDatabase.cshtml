@page
@model TestDatabaseModel
@{
    ViewData["Title"] = "Test de la Base de Données";
}

<div class="container mt-5">
    <h1>Test de Connexion à la Base de Données</h1>
    
    @if (Model.IsConnected)
    {
        <div class="alert alert-success" role="alert">
            <h4 class="alert-heading">Connexion Réussie !</h4>
            <p>La base de données est correctement configurée et connectée.</p>
        </div>

        <div class="row mt-4">
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">📊 Statistiques des Données</h5>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">Transporteurs: <strong>@Model.TransporteurCount</strong></li>
                            <li class="list-group-item">Camions: <strong>@Model.CamionCount</strong></li>
                            <li class="list-group-item">Chauffeurs: <strong>@Model.ChauffeurCount</strong></li>
                            <li class="list-group-item">Clients: <strong>@Model.ClientCount</strong></li>
                            <li class="list-group-item">Tournées: <strong>@Model.TourneeCount</strong></li>
                            <li class="list-group-item">Livraisons: <strong>@Model.LivraisonCount</strong></li>
                            <li class="list-group-item">Coûts: <strong>@Model.CoutCount</strong></li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">📋 Exemples de Données</h5>
                        @if (Model.Transporteurs.Any())
                        {
                            <h6>Transporteurs :</h6>
                            <ul>
                                @foreach (var t in Model.Transporteurs)
                                {
                                    <li>@t.Nom - @t.Telephone</li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-md-12">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">🚚 Dernières Tournées</h5>
                        @if (Model.Tournees.Any())
                        {
                            <table class="table table-hover mt-3">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Date</th>
                                        <th>Statut</th>
                                        <th>Chauffeur</th>
                                        <th>Coût</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in Model.Tournees)
                                    {
                                        <tr>
                                            <td>@t.TourneeId</td>
                                            <td>@t.DateTournee.ToString("yyyy-MM-dd")</td>
                                            <td><span class="badge bg-info">@t.StatutTournee</span></td>
                                            <td>@t.Chauffeur.Nom @t.Chauffeur.Prenom</td>
                                            <td class="fw-bold">@t.CoutTotal.ToString("N2") DH</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <p class="text-warning">Aucune tournée trouvée. Vérifiez si les données de test ont été chargées.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">❌ Échec de la Connexion !</h4>
            <p><strong>Erreur :</strong> @Model.ErrorMessage</p>
            <hr>
            <p class="mb-0">
                <strong>Étapes de dépannage :</strong>
                <ul>
                    <li>Vérifiez que SQL Server est en cours d'exécution</li>
                    <li>Vérifiez la chaîne de connexion dans appsettings.json</li>
                    <li>Exécutez le script : Database/TMS_Database_Script.sql</li>
                    <li>Vérifiez que la base de données TMSDatabase a été créée</li>
                </ul>
            </p>
        </div>
    }
</div>

<style>
    body {
        background-color: #f8f9fa;
    }
    .container {
        background-color: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }
    .card {
        border: none;
        border-radius: 10px;
    }
</style>