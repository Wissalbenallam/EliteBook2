@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using TMS_Project
@using TMS_Project.Models
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TMS_Project</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-page="/Index">TMS_Project</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-page="/Index">Accueil</a></li>

                        <!-- Razor Page (Transporteurs si vous avez une page Razor) -->
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Transporteurs/IndexTrasporteurs">🏢 Transporteurs (Pages)</a>
                        </li>

                        <!-- MVC controllers (assurez-vous que Views\<Controller>\Index.cshtml existent) -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Camion" asp-action="Index">🚛 Camions (MVC)</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Chauffeur" asp-action="Index">👤 Chauffeurs (MVC)</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Livraison" asp-action="Index">📦 Livraisons (MVC)</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Tournee" asp-action="Index">📅 Tournées (MVC)</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">&copy; 2026 - TMS_Project</div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>