@model IEnumerable<TMS_Project.Models.Camion>

@{
    ViewData["Title"] = "Camions";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Camions</h1>
        <p class="page-lead">Consulte la flotte disponible, les immatriculations et les rattachements transporteur.</p>
    </div>
    <a asp-controller="Camion" asp-action="Create" class="btn-soft">
        <i class="bi bi-plus-circle"></i> Créer un camion
    </a>
</div>

<div class="table-shell">
    <table class="table dashboard-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Immatriculation</th>
                <th>Transporteur</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="4">
                    <div class="empty-state">
                        <i class="bi bi-truck"></i>
                        <div class="mt-2">Aucun camion n'est encore disponible.</div>
                    </div>
                </td>
            </tr>
        }
        else
        {
            foreach (var c in Model)
            {
                <tr>
                    <td><span class="badge-soft">#@c.CamionId</span></td>
                    <td class="fw-semibold">@c.Immatriculation</td>
                    <td>@(c.Transporteur?.Nom ?? "Non affecté")</td>
                    <td class="text-end">
                        <a asp-controller="Camion" asp-action="Details" asp-route-id="@c.CamionId" class="btn-soft">
                            <i class="bi bi-eye"></i> Détails
                        </a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>
