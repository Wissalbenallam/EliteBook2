@model TMS_Project.ViewModels.LivraisonFormViewModel
@{
    ViewData["Title"] = "Nouvelle Livraison";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-plus-circle"></i> Nouvelle Livraison</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Retour
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">

                <div class="col-md-6">
                    <label asp-for="Livraison.ClientId" class="form-label fw-bold">
                        <i class="bi bi-person-fill"></i> Client
                    </label>
                    <select asp-for="Livraison.ClientId" asp-items="Model.Clients" class="form-select">
                        <option value="">-- Sélectionner un client --</option>
                    </select>
                    <span asp-validation-for="Livraison.ClientId" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Livraison.Adresse" class="form-label fw-bold">
                        <i class="bi bi-geo-alt"></i> Adresse de livraison
                    </label>
                    <input asp-for="Livraison.Adresse" class="form-control"
                           placeholder="Ex: 12 Rue Mohammed V, Casablanca" />
                    <span asp-validation-for="Livraison.Adresse" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="Livraison.PoidsKg" class="form-label fw-bold">
                        <i class="bi bi-box"></i> Poids (kg)
                    </label>
                    <input asp-for="Livraison.PoidsKg" class="form-control"
                           type="number" min="1" placeholder="0" />
                    <span asp-validation-for="Livraison.PoidsKg" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="Livraison.DateLivraison" class="form-label fw-bold">
                        📅 Date de livraison prévue
                    </label>
                    <input asp-for="Livraison.DateLivraison" class="form-control" type="date" />
                    <span asp-validation-for="Livraison.DateLivraison" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="Livraison.StatutLivraison" class="form-label fw-bold">Statut</label>
                    <select asp-for="Livraison.StatutLivraison" class="form-select">
                        <option value="En attente">En attente</option>
                        <option value="En cours">En cours</option>
                        <option value="Livrée">Livrée</option>
                        <option value="Échouée">Échouée</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label asp-for="Livraison.TourneeId" class="form-label fw-bold">
                        <i class="bi bi-map"></i> Affecter à une tournée
                    </label>
                    <select asp-for="Livraison.TourneeId" asp-items="Model.Tournees" class="form-select">
                        <option value="0">-- Sans tournée --</option>
                    </select>
                </div>

            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-save"></i> Enregistrer
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg">Annuler</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
