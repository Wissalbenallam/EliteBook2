@model TMS_Project.Models.Livraison
@{
    ViewData["Title"] = "Supprimer Livraison";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-danger"><i class="bi bi-trash"></i> Supprimer Livraison #@Model.LivraisonId</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Retour</a>
</div>

<div class="card border-danger shadow-sm">
    <div class="card-header bg-danger text-white">
        <i class="bi bi-exclamation-triangle-fill"></i> Confirmation de suppression
    </div>
    <div class="card-body">
        <p class="fs-5">Êtes-vous sûr de vouloir supprimer cette livraison ?</p>

        <table class="table table-borderless">
            <tr><th width="30%">ID :</th>       <td>#@Model.LivraisonId</td></tr>
            <tr><th>Client :</th>    <td>@Model.Client?.Nom</td></tr>
            <tr><th>Adresse :</th>   <td>@Model.Adresse</td></tr>
            <tr><th>Poids :</th>     <td>@Model.PoidsKg kg</td></tr>
            <tr><th>Statut :</th>    <td>@Model.StatutLivraison</td></tr>
            <tr>
                <th>Tournée :</th>
                <td>
                    @if (Model.Tournee != null)
                    {
                        <span class="badge bg-warning text-dark">
                            Affectée à Tournée #@Model.TourneeId
                        </span>
                    }
                    else
                    {

                        <span>—</span>
                    }
                </td>
            </tr>
        </table>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.LivraisonId" />
            <button type="submit" class="btn btn-danger btn-lg">
                <i class="bi bi-trash-fill"></i> Oui, supprimer
            </button>
            <a asp-action="Index" class="btn btn-secondary btn-lg ms-2">Annuler</a>
        </form>
    </div>
</div>
