@model IEnumerable<TMS_Project.Models.Livraison>
@{
    ViewData["Title"] = "Livraisons";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-box-seam"></i> Liste des Livraisons</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nouvelle Livraison
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0 align-middle">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Client</th>
                    <th>Adresse</th>
                    <th>Poids (kg)</th>
                    <th>Date prévue</th>
                    <th>Statut</th>
                    <th>Tournée</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                            Aucune livraison enregistrée.
                        </td>
                    </tr>
                }
                @foreach (var l in Model)
                {
                    var cls = l.StatutLivraison switch
                    {
                        "Livrée" => "bg-success",
                        "En cours" => "bg-warning text-dark",
                        "Échouée" => "bg-danger",
                        _ => "bg-secondary"
                    };
                    <tr>
                        <td><strong>#@l.LivraisonId</strong></td>
                        <td>@l.Client?.Nom</td>
                        <td>@l.Adresse</td>
                        <td>@l.PoidsKg</td>
                        <td>@l.DateLivraison.ToString("dd/MM/yyyy")</td>
                        <td><span class="badge @cls">@l.StatutLivraison</span></td>
                        <td>
                            @if (l.Tournee != null)
                            {
                                <a asp-controller="Tournee" asp-action="Details"
                                   asp-route-id="@l.TourneeId"
                                   class="badge bg-info text-dark text-decoration-none">
                                    Tournée #@l.TourneeId
                                </a>
                            }
                            else
                            {
                                <span class="badge bg-light text-muted border">Non affectée</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@l.LivraisonId"
                               class="btn btn-sm btn-outline-info" title="Détails">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@l.LivraisonId"
                               class="btn btn-sm btn-outline-warning" title="Modifier">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@l.LivraisonId"
                               class="btn btn-sm btn-outline-danger" title="Supprimer">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
