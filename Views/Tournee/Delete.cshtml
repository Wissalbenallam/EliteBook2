@model TMS_Project.Models.Tournee
@{
    ViewData["Title"] = "Supprimer Tournķe";
}

<h3>Supprimer la tournķe #@Model.TourneeId</h3>

<div class="alert alert-warning">
    Voulez-vous vraiment supprimer cette tournķe ?
</div>

<table class="table">
    <tr><th>ID</th><td>@Model.TourneeId</td></tr>
    <tr><th>Date</th><td>@Model.DateTournee.ToString("dd/MM/yyyy HH:mm")</td></tr>
    <tr><th>Co¹t total</th><td>@Model.CoutTotal.ToString("C")</td></tr>
</table>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="TourneeId" />
    <button type="submit" class="btn btn-danger">Supprimer</button>
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>